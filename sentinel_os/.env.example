# Copy to .env and fill in real values. .env itself is gitignored --
# never commit real credentials.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iceberg
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg

# Required for live governance decisions. Without it the governor runs in
# fail-closed no-client mode (see claude_governance_api.py).
CLAUDE_API_KEY=

# Only needed if ingesting real Twilio call logs.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Comma-separated API keys for the resilient API server.
ICEBERG_API_KEYS=

PORT=9090
CERT_FILE=./certs/cert.pem
KEY_FILE=./certs/key.pem
